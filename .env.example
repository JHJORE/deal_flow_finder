# Copy to .env and fill in real values. Never commit .env.

# Firecrawl — web scraping for firm pages and partner blogs.
FIRECRAWL_API_KEY=

# twitterapi.io — X / Twitter activity for partners and founders.
TWITTERAPI_IO_KEY=

# Proxycurl — LinkedIn profile and company data.
PROXYCURL_API_KEY=

# Anthropic — Claude for tagging, signal narrative, digest copy (Phase 4/5).
ANTHROPIC_API_KEY=

# SEC EDGAR requires a User-Agent header identifying who is hitting the API.
# Format: "Org Name contact@example.com"
EDGAR_USER_AGENT=LAUNCH Research contact@launch.vc
