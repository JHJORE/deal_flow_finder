APP_ENV=development

# Firecrawl — scrapes firm team pages
# https://www.firecrawl.dev/ → Dashboard → API Keys
FIRECRAWL_API_KEY=

# SEC EDGAR — no API key, but their fair-access policy requires a
# descriptive User-Agent. Format: "Your Name your-email@domain.com"
SEC_USER_AGENT=

# TwitterAPI.io — partner X/Twitter activity
# https://twitterapi.io/ → Dashboard
TWITTERAPI_IO_KEY=

# Apify — partner LinkedIn activity via the
# harvestapi~linkedin-profile-posts actor
# https://console.apify.com/settings/integrations
APIFY_API_TOKEN=
# APIFY_LINKEDIN_ACTOR_ID=harvestapi~linkedin-profile-posts

# Google Gemini — required for
# /api/firms/{domain}/partner-profiles?summarize=true
# https://aistudio.google.com/apikey
GEMINI_API_KEY=

# Postgres — reserved; not wired into any use case yet
# DATABASE_URL=
